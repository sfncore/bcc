#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/gt/bcc/crew/berry/node_modules/.pnpm/vite-plus@0.1.12_vite@8.0.0/node_modules/vite-plus/node_modules:/home/ubuntu/gt/bcc/crew/berry/node_modules/.pnpm/vite-plus@0.1.12_vite@8.0.0/node_modules:/home/ubuntu/gt/bcc/crew/berry/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/gt/bcc/crew/berry/node_modules/.pnpm/vite-plus@0.1.12_vite@8.0.0/node_modules/vite-plus/node_modules:/home/ubuntu/gt/bcc/crew/berry/node_modules/.pnpm/vite-plus@0.1.12_vite@8.0.0/node_modules:/home/ubuntu/gt/bcc/crew/berry/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vite-plus/bin/vp" "$@"
else
  exec node  "$basedir/../vite-plus/bin/vp" "$@"
fi
